# Ignore local Terraform state files.
.terraform/
.terraform.lock.hcl
terraform.tfstate*
.terraform.tfstate.lock.info

# Ignore generated grid and exascale files
.grid_image_id
exascale_outputs.*

# Ignore key files
*.pem
*.pub

# ExaScale secrets & generated files 
.grid_image_id
exadb_private_key.pem
exadb_public_key.pub
exascale_outputs.yaml
